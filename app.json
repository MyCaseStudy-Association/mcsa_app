{
  "expo": {
    "name": "Portibilify",
    "slug": "portibilify",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app-icon.png",
    "scheme": "portibilify",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/icons/app-icon.png"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#DFF9F6",
        "foregroundImage": "./assets/icons/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/icons/adaptive-icon-background.png",
        "monochromeImage": "./assets/icons/adaptive-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DFF9F6",
          "image": "./assets/icons/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2ec627b7-650f-410a-b11e-5738aa82ddfb"
      }
    },
    "owner": "rrahulppanchal"
  }
}
